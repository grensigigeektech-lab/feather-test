# ─────────────────────────────────────────────────────────────
# iGeek Test Project — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
APP_NAME=igeek-test-project
APP_ENV=development          # development | staging | production
APP_PORT=8000
DEBUG=true

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-min-32-chars
TOKEN_EXPIRY_SECONDS=3600    # 1 hour
LOGIN_TIMEOUT_SECONDS=30
MAX_LOGIN_RETRIES=3

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/igeek_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis (for session store in production) ───────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email / SMTP ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── Slack ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_DEV_TEAM=#dev-team

# ── GitHub ────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=igeek-test-project

# ── Linear ────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_your-linear-api-key
LINEAR_TEAM_ID=your-linear-team-id

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json              # json | text
